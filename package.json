{
  "name": "@varel/cli",
  "version": "0.2.2",
  "description": "Varel CLI for core initialization and Hyperdrive setup.",
  "type": "module",
  "license": "UNLICENSED",
  "homepage": "https://www.varel.dev",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/varelhq/varel-cli.git"
  },
  "bugs": {
    "url": "https://github.com/varelhq/varel-cli/issues"
  },
  "keywords": [
    "varel",
    "cli",
    "core",
    "codex",
    "mcp"
  ],
  "packageManager": "pnpm@9.15.0",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "bin": {
    "varel": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "ink": "^6.5.0",
    "open": "^10.2.0",
    "react": "^19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
